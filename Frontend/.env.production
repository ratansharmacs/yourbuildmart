# In production, frontend and backend are served from the same domain.
# Leave VITE_API_URL empty so all /uploads/... and /api/... paths resolve to the same origin.
# If your backend is on a separate subdomain (e.g. api.yourbuildmart.com), set it here:
# VITE_API_URL=https://api.yourbuildmart.com
VITE_API_URL=
