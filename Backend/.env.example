# ─── YourBuildMart Backend — Environment Variables ──────────────────────────
# Copy this file to .env and fill in real values.
# .env is git-ignored — never commit real credentials.

# MySQL
DB_USERNAME=root
DB_PASSWORD=your_mysql_password_here

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=replace-with-a-random-64-char-secret

# Admin account seeded on first boot
ADMIN_EMAIL=info@yourbuildmart.com
ADMIN_PASSWORD=ChangeMe@StrongPassword123

# Gmail SMTP (App Password, not your real Gmail password)
MAIL_USERNAME=your_gmail_address@gmail.com
MAIL_PASSWORD=your_16_char_app_password
EMAIL_ENABLED=false

# Frontend origin used in email links (welcome, password-changed, etc.)
FRONTEND_URL=http://localhost:5173
