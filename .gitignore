# ─── Secrets — NEVER commit ──────────────────────────────────────────────
**/.env
**/.env.local
**/.env.*.local

# ─── Backend (Spring Boot / Maven) ───────────────────────────────────────
Backend/target/
Backend/uploads/
!Backend/uploads/.gitkeep
Backend/*.log
Backend/HELP.md
.mvn/wrapper/maven-wrapper.jar
*.class

# ─── Frontend (Vite / React) ─────────────────────────────────────────────
Frontend/node_modules/
Frontend/dist/
Frontend/.vite/
Frontend/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── IDE / OS ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.iml
.DS_Store
Thumbs.db

# ─── Backups / scratch files ──────────────────────────────────────────────
*.bak
*.tmp
/uploads
Backend/src/main/resources/.env.properties
